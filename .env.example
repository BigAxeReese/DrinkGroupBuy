# Backend
PORT=3000
AUTH_SESSION_SECRET=replace_with_backend_session_secret_at_least_16_chars

# LINE Pay sandbox settings
# Copy this file to backend/.env and replace placeholders with your sandbox channel values.
# Do not put LINE_PAY_CHANNEL_SECRET in mobile/.env or any EXPO_PUBLIC_* variable.
LINE_PAY_ENV=sandbox
LINE_PAY_API_BASE_URL=https://sandbox-api-pay.line.me
LINE_PAY_CHANNEL_ID=replace_with_line_pay_channel_id
LINE_PAY_CHANNEL_SECRET=replace_with_line_pay_channel_secret
LINE_PAY_CURRENCY=TWD

# For Expo Web on the same computer, localhost works.
# For Android phone testing, use a public tunnel URL or your reachable backend URL.
LINE_PAY_CONFIRM_URL=http://localhost:3000/api/payments/line-pay/confirm
LINE_PAY_CANCEL_URL=http://localhost:3000/api/payments/line-pay/cancel
